# Browser Worker Dockerfile — Playwright + Chromium for browser-based LLM providers
FROM python:3.12-slim

WORKDIR /app

# Install system dependencies for Playwright/Chromium
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libatspi2.0-0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libx11-xcb1 \
    && (apt-get install -y --no-install-recommends fonts-noto-cjk || true) \
    && rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright and Chromium browser
RUN playwright install chromium

# Copy source code
COPY . .

# Create directories
RUN mkdir -p /app/data /app/browser_data

# Default: run as Celery browser worker (concurrency=1 for browser safety)
CMD ["celery", "-A", "app.celery_app:celery_app", "worker", "-Q", "browser", "--loglevel=info", "--concurrency=1"]
